{
  "name": "coart-canvas",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "description": "A clean-room Codex native infinite-canvas widget for AI image, HTML, slides, and annotation workflows.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "check": "tsc -p tsconfig.node.json --noEmit",
    "test": "node --test tests/*.test.ts",
    "quality": "npm run check && npm run typecheck && npm test && npm run build && npm run probe:mcp && npm run probe:http && npm run probe:widget",
    "probe:mcp": "node scripts/probe-mcp.ts",
    "probe:http": "node scripts/probe-http.ts",
    "probe:widget": "node scripts/probe-widget-loader.ts",
    "start:http": "node scripts/start-http.ts"
  },
  "dependencies": {
    "@ferric-canvas/web": "file:vendor/ferric-canvas",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fractional-indexing": "^3.2.0",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright-core": "^1.61.1",
    "typescript": "^7.0.2"
  }
}
